{
  "name": "grantfox-webhook-sync",
  "version": "0.1.0",
  "description": "GitHub webhook service that syncs OSS contributions to GrantFox and triggers Stellar reputation updates",
  "private": true,
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@octokit/webhooks": "^13.4.0",
    "@octokit/rest": "^21.0.2",
    "@stellar/stellar-sdk": "^13.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
