# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub API (for fetching PR/issue details)
GITHUB_TOKEN=ghp_...

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Operator keypair (used to call the reputation contract)
# KEEP THIS SECRET — never commit to git
STELLAR_OPERATOR_SECRET=S...

# Deployed contract IDs (from deploy.sh output)
REPUTATION_CONTRACT_ID=C...
ESCROW_CONTRACT_ID=C...

# GrantFox API (optional — to sync contribution data to the platform)
GRANTFOX_API_URL=https://api.grantfox.xyz
GRANTFOX_API_KEY=your_api_key_here

# Server
PORT=3001
NODE_ENV=development
